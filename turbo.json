{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "CORS_ORIGIN",
    "JWT_ACCESS_SECRET",
    "JWT_ACCESS_EXPIRES_IN",
    "JWT_REFRESH_EXPIRES_IN",
    "ADMIN_EMAIL",
    "ADMIN_PASSWORD"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"],
      "env": [
        "DATABASE_URL",
        "CORS_ORIGIN",
        "JWT_ACCESS_SECRET",
        "JWT_ACCESS_EXPIRES_IN",
        "JWT_REFRESH_EXPIRES_IN",
        "ADMIN_EMAIL",
        "ADMIN_PASSWORD"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "env": [
        "DATABASE_URL",
        "CORS_ORIGIN",
        "JWT_ACCESS_SECRET",
        "JWT_ACCESS_EXPIRES_IN",
        "JWT_REFRESH_EXPIRES_IN",
        "ADMIN_EMAIL",
        "ADMIN_PASSWORD"
      ]
    },
    "test": {
      "dependsOn": ["^test"]
    }
  }
}
