{
  "name": "black-med-collective-platform",
  "private": true,
  "version": "1.0.0",
  "engines": {
    "node": ">=20 <25"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/engines",
      "bcrypt",
      "esbuild",
      "prisma",
      "sharp"
    ]
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @bmc/api prisma:generate",
    "db:migrate": "pnpm --filter @bmc/api prisma:migrate",
    "db:seed": "pnpm --filter @bmc/api prisma:seed"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^6.0.3"
  }
}
